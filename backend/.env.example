# Identidad de la API
API_SERVICE_NAME=ai-support-integration-api
API_VERSION=1.0.0
PORT=2099

# URL base del servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Ruta para listar modelos (por defecto /tags; en algunas versiones es /api/tags)
OLLAMA_TAGS_PATH=/tags

# Timeout HTTP hacia Ollama (ms)
OLLAMA_TIMEOUT_MS=60000

# Modelo por defecto para POST /ollama/chat (debe existir en el servidor: ollama pull …)
OLLAMA_DEFAULT_MODEL=llama3.2

# Prompt de sistema del asistente de soporte (opcional)
# OLLAMA_SYSTEM_PROMPT=Eres un agente de soporte…

# Timeout solo para peticiones de chat (ms)
OLLAMA_CHAT_TIMEOUT_MS=120000

# Orígenes CORS separados por coma
# CORS_ORIGIN=http://localhost:4321